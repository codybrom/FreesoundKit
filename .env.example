# FreesoundKit local API smoke test credentials

# API key for read-only endpoints (search, sound lookup, etc.)
# Get one at https://freesound.org/apiv2/apply
FREESOUND_API_KEY=

# OAuth2 client credentials (for /me, uploads, downloads, bookmarks, etc.)
# Register an app at https://freesound.org/apiv2/apply
FREESOUND_CLIENT_ID=
FREESOUND_CLIENT_SECRET=

# OAuth tokens (set after running oauth-exchange)
FREESOUND_ACCESS_TOKEN=
FREESOUND_REFRESH_TOKEN=
